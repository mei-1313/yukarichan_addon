{
  "manifest_version": 3,
  "name": "ゆかりちゃんアドオン",
  "version": "1.0.0",
  "description": "マスターのWeb閲覧にお淑やかなゆかりちゃんが寄り添い、Gemini APIを介して博識な豆知識や感想を述べるアドオンです。",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "options_page": "src/options.html",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/yukari_images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
